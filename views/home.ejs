<%- include('partials/header') %>

<!-- ══════ HERO ══════ -->
<section class="hero-section">
  <div class="hero-bg-glow glow-1"></div>
  <div class="hero-bg-glow glow-2"></div>
  <div class="hero-particles"></div>

  <div class="container hero-content">
    <div class="row align-items-center">
      <div class="col-lg-6 mb-5 mb-lg-0">
        <div class="hero-badge fade-in">
          <span class="dot"></span> Now Accepting New Projects
        </div>
        <h1 class="hero-title fade-in">
          Building <span class="gradient-text">Scalable Software</span> Solutions for the Digital Future
        </h1>
        <p class="hero-subtitle fade-in">
          We craft innovative digital products that transform businesses. From concept to deployment, our expert team delivers excellence at every stage.
        </p>
        <div class="hero-buttons fade-in">
          <a href="/signup" class="btn btn-cw-primary btn-lg">Get Started <i class="bi bi-arrow-right ms-2"></i></a>
          <a href="/contact" class="btn btn-cw-outline btn-lg">Contact Us <i class="bi bi-chat-dots ms-2"></i></a>
        </div>
      </div>
      <div class="col-lg-6 d-none d-lg-block">
        <div class="hero-illustration">
          <div class="hero-circle"></div>
          <div class="hero-circle-outer"></div>
          <div class="floating-card card-1"><i class="bi bi-code-slash"></i><span>Frontend</span></div>
          <div class="floating-card card-2"><i class="bi bi-database"></i><span>Backend</span></div>
          <div class="floating-card card-3"><i class="bi bi-cloud"></i><span>Cloud</span></div>
          <div class="floating-card card-4"><i class="bi bi-phone"></i><span>Mobile</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══════ SERVICES HIGHLIGHTS ══════ -->
<section class="section-padding bg-white">
  <div class="container">
    <div class="text-center mb-5">
      <span class="section-badge scroll-reveal"><i class="bi bi-grid"></i> What We Do</span>
      <h2 class="section-title scroll-reveal">Our Core Services</h2>
      <p class="section-subtitle scroll-reveal">Comprehensive software solutions tailored to drive your business forward</p>
    </div>

    <div class="row g-4 stagger-children">
      <div class="col-md-6 col-lg-4">
        <div class="service-card scroll-reveal">
          <div class="service-icon"><i class="bi bi-globe2"></i></div>
          <h5>Web Development</h5>
          <p>Custom web applications built with modern frameworks and scalable architecture</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-4">
        <div class="service-card scroll-reveal">
          <div class="service-icon"><i class="bi bi-phone"></i></div>
          <h5>Mobile Apps</h5>
          <p>Native and cross-platform mobile applications for iOS and Android</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-4">
        <div class="service-card scroll-reveal">
          <div class="service-icon"><i class="bi bi-cloud-arrow-up"></i></div>
          <h5>Cloud Solutions</h5>
          <p>Scalable cloud infrastructure and backend services for enterprise needs</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-4">
        <div class="service-card scroll-reveal">
          <div class="service-icon"><i class="bi bi-palette"></i></div>
          <h5>UI/UX Design</h5>
          <p>User-centered design that creates intuitive and engaging digital experiences</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-4">
        <div class="service-card scroll-reveal">
          <div class="service-icon"><i class="bi bi-robot"></i></div>
          <h5>AI & Automation</h5>
          <p>Intelligent automation solutions powered by machine learning algorithms</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-4">
        <div class="service-card scroll-reveal">
          <div class="service-icon"><i class="bi bi-tools"></i></div>
          <h5>Maintenance</h5>
          <p>Ongoing support and optimization to keep your software running at peak performance</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══════ WHY CHOOSE US ══════ -->
<section class="section-padding" style="background: var(--cw-light);">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-6 mb-5 mb-lg-0">
        <span class="section-badge scroll-reveal"><i class="bi bi-award"></i> Why CodeWave</span>
        <h2 class="section-title scroll-reveal">Why Leading Companies Choose Us</h2>
        <p class="section-subtitle scroll-reveal" style="margin: 0 0 28px;">We combine technical expertise with a deep understanding of business needs to deliver solutions that make a real impact.</p>

        <div class="d-flex flex-column gap-3 stagger-children">
          <div class="feature-item scroll-reveal"><i class="bi bi-check-circle-fill text-success"></i> 100% On-Time Delivery Guarantee</div>
          <div class="feature-item scroll-reveal"><i class="bi bi-check-circle-fill text-success"></i> Dedicated Project Managers</div>
          <div class="feature-item scroll-reveal"><i class="bi bi-check-circle-fill text-success"></i> Agile Development Methodology</div>
          <div class="feature-item scroll-reveal"><i class="bi bi-check-circle-fill text-success"></i> 24/7 Technical Support</div>
          <div class="feature-item scroll-reveal"><i class="bi bi-check-circle-fill text-success"></i> Enterprise-Grade Security</div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="why-choose-visual scroll-reveal">
          <div class="visual-ring ring-1"></div>
          <div class="visual-ring ring-2"></div>
          <div class="visual-ring ring-3"></div>
          <div class="visual-center">
            <i class="bi bi-shield-check"></i>
            Trusted
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══════ STATS ══════ -->
<section class="stats-section">
  <div class="container">
    <div class="row text-center">
      <div class="col-6 col-md-3 mb-4 mb-md-0">
        <div class="stat-item scroll-reveal">
          <div class="stat-number" data-count="250">0</div>
          <div class="stat-label">Projects Delivered</div>
        </div>
      </div>
      <div class="col-6 col-md-3 mb-4 mb-md-0">
        <div class="stat-item scroll-reveal">
          <div class="stat-number" data-count="120">0</div>
          <div class="stat-label">Happy Clients</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-item scroll-reveal">
          <div class="stat-number" data-count="8">0</div>
          <div class="stat-label">Years Experience</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-item scroll-reveal">
          <div class="stat-number" data-count="35">0</div>
          <div class="stat-label">Team Members</div>
        </div>
      </div>
