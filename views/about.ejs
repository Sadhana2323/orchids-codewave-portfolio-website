<%- include('partials/header') %>

<section class="page-header">
  <div class="page-header-content">
    <h1 class="fade-in">About Us</h1>
    <p class="fade-in">Discover our story, mission, and the people behind CodeWave</p>
    <div class="breadcrumb-nav fade-in">
      <a href="/">Home</a>
      <i class="bi bi-chevron-right" style="font-size:.7rem;color:rgba(255,255,255,.3)"></i>
      <span>About Us</span>
    </div>
  </div>
</section>

<!-- ══════ COMPANY INTRO ══════ -->
<section class="section-padding">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-6 mb-5 mb-lg-0">
        <span class="section-badge scroll-reveal"><i class="bi bi-building"></i> Our Story</span>
        <h2 class="section-title scroll-reveal">Innovating Since 2018</h2>
        <div class="about-intro-text scroll-reveal">
          <p>CodeWave Technologies was founded with a singular vision: to make cutting-edge software development accessible to businesses of all sizes. What started as a small team of passionate developers has grown into a full-service digital agency.</p>
          <p>Today, we partner with startups, SMBs, and enterprises across the globe to build software that solves real problems. Our team combines deep technical expertise with creative thinking to deliver solutions that drive measurable results.</p>
          <p>We believe in transparent communication, agile methodology, and continuous improvement. Every project we take on is a partnership built on trust and a shared commitment to excellence.</p>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="about-visual scroll-reveal">
          <div class="about-card-stack">
            <div class="about-card ac-1"><i class="bi bi-lightbulb"></i> Innovation First</div>
            <div class="about-card ac-2"><i class="bi bi-people"></i> Client Focused</div>
            <div class="about-card ac-3"><i class="bi bi-graph-up"></i> Results Driven</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══════ MISSION & VISION ══════ -->
<section class="section-padding" style="background: var(--cw-light);">
  <div class="container">
    <div class="text-center mb-5">
      <span class="section-badge scroll-reveal"><i class="bi bi-compass"></i> Direction</span>
      <h2 class="section-title scroll-reveal">Our Mission & Vision</h2>
    </div>
    <div class="row g-4">
      <div class="col-md-6">
        <div class="mission-card scroll-reveal">
          <div class="mission-icon"><i class="bi bi-rocket-takeoff"></i></div>
          <h3>Our Mission</h3>
          <p>To empower businesses with innovative, reliable, and scalable software solutions that accelerate digital transformation. We strive to deliver exceptional value through cutting-edge technology, transparent processes, and unwavering commitment to quality.</p>
        </div>
      </div>
      <div class="col-md-6">
        <div class="mission-card vision scroll-reveal">
          <div class="mission-icon"><i class="bi bi-eye"></i></div>
          <h3>Our Vision</h3>
          <p>To become a globally recognized software development leader known for transforming ideas into impactful digital products. We envision a future where every business, regardless of size, has access to world-class technology solutions.</p>
        </div>
      </div>
    </div>
  </div>
</section>

